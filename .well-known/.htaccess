# Serve the RFC 9727 API catalog with its registered media type.
<Files "api-catalog">
    ForceType application/linkset+json
</Files>

# Allow browser-based agents to fetch discovery metadata cross-origin.
# These files are public, read-only, and safe to expose to any origin.
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
</IfModule>
