# Serve the RFC 9727 API catalog with its registered media type.
<Files "api-catalog">
    ForceType application/linkset+json
</Files>

# Serve agents.json with proper content type for DNS-AID discovery
<Files "agents.json">
    ForceType application/json
</Files>

# Serve security.txt with proper content type
<Files "security.txt">
    ForceType text/plain
</Files>

# Allow browser-based agents and crawlers to fetch discovery metadata cross-origin.
# These files are public, read-only, and safe to expose to any origin.
# Essential for agent discovery from other domains.
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Cache-Control "no-cache, must-revalidate"
    Header always merge Vary "Accept"
</IfModule>
