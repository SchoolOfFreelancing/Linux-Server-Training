############################################
# School Of Freelancing
############################################
Options -Indexes
DirectoryIndex index.html
RewriteEngine On

##################################################
# Localhost only (no HTTPS/WWW force)
##################################################
RewriteCond %{HTTP_HOST} ^(localhost|127\.0\.0\.1)$ [NC]
RewriteRule ^ - [L]

##################################################
# Redirect /index.html to /
##################################################
RewriteRule ^index\.html$ / [R=301,L]

##################################################
# Redirect directory index.html to /
##################################################
RewriteRule ^(.+)/index\.html$ /$1/ [R=301,L]

##################################################
# Redirect old flat HTML pages to current folders
##################################################
RewriteRule ^training\.html$ /freelancing-training/ [R=301,L]
RewriteRule ^enrollment\.html$ /get-started/ [R=301,L]
RewriteRule ^tech-support\.html$ /linux-it-services/ [R=301,L]
RewriteRule ^support\.html$ /linux-it-services/ [R=301,L]
RewriteRule ^get-support\.html$ /linux-it-services/ [R=301,L]
RewriteRule ^get_support\.html$ /linux-it-services/ [R=301,L]
RewriteRule ^testimonials\.html$ /resource-center/testimonials/ [R=301,L]
RewriteRule ^about\.html$ /about-us/ [R=301,L]
RewriteRule ^faq\.html$ /resource-center/faqs/ [R=301,L]
RewriteRule ^privacy-policy\.html$ /legal/privacy-policy/ [R=301,L]
RewriteRule ^terms\.html$ /legal/terms-and-conditions/ [R=301,L]
RewriteRule ^contact\.html$ /get-started/ [R=301,L]

##################################################
# Redirect deleted section folders to their new
# equivalents from the 2026-07 site restructure
##################################################
RewriteRule ^training/enroll(/.*)?$ /get-started/ [R=301,L]
RewriteRule ^training/oldenroll(/.*)?$ /get-started/ [R=301,L]
RewriteRule ^training/enroll1(/.*)?$ /get-started/ [R=301,L]
RewriteRule ^training/files(/.*)?$ /get-started/ [R=301,L]
RewriteRule ^training/?$ /freelancing-training/ [R=301,L]
RewriteRule ^tech-support/get-support/?$ /linux-it-services/ [R=301,L]
RewriteRule ^tech-support/?$ /linux-it-services/ [R=301,L]
RewriteRule ^about/?$ /about-us/ [R=301,L]
RewriteRule ^contact/?$ /get-started/ [R=301,L]
RewriteRule ^testimonials/?$ /resource-center/testimonials/ [R=301,L]
RewriteRule ^faq/?$ /resource-center/faqs/ [R=301,L]
RewriteRule ^terms/?$ /legal/terms-and-conditions/ [R=301,L]
RewriteRule ^privacy/?$ /legal/privacy-policy/ [R=301,L]
RewriteRule ^refund/?$ /legal/refund-policy/ [R=301,L]
RewriteRule ^training-rules/?$ /legal/training-rules/ [R=301,L]
RewriteRule ^verify/?$ /legal/credential-verification/ [R=301,L]

##################################################
# Internally load index.html for clean folder URLs
##################################################
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L]

##################################################
# Browser Cache
##################################################
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

##################################################
# GZIP Compression
##################################################
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

##################################################
# Security Headers
##################################################
<IfModule mod_headers.c>
    Header always set X-Frame-Options SAMEORIGIN
    Header always set X-Content-Type-Options nosniff
    Header always set Referrer-Policy strict-origin-when-cross-origin
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
