############################################
# School Of Freelancing
############################################
Options -Indexes
DirectoryIndex index.html
RewriteEngine On

##################################################
# Localhost only (no HTTPS/WWW force)
##################################################
RewriteCond %{HTTP_HOST} ^(localhost|127\.0\.0\.1)$ [NC]
RewriteRule ^ - [L]

##################################################
# Redirect /index.html to /
##################################################
RewriteRule ^index\.html$ / [R=301,L]

##################################################
# Redirect directory index.html to /
##################################################
RewriteRule ^(.+)/index\.html$ /$1/ [R=301,L]

##################################################
# Redirect old flat HTML pages to current folders
# (absolute target: guarantees a single-hop 301 even
# when the inbound request is also non-canonical
# host/scheme, instead of chaining through the
# HTTPS+www rule above on a second request)
##################################################
RewriteRule ^training\.html$ https://www.schooloffreelancing.com/freelancing-training/ [R=301,L]
RewriteRule ^enrollment\.html$ https://www.schooloffreelancing.com/contact-us/ [R=301,L]
RewriteRule ^tech-support\.html$ https://www.schooloffreelancing.com/linux-ai-services/ [R=301,L]
RewriteRule ^support\.html$ https://www.schooloffreelancing.com/linux-ai-services/ [R=301,L]
RewriteRule ^get-support\.html$ https://www.schooloffreelancing.com/linux-ai-services/ [R=301,L]
RewriteRule ^get_support\.html$ https://www.schooloffreelancing.com/linux-ai-services/ [R=301,L]
RewriteRule ^testimonials\.html$ https://www.schooloffreelancing.com/resource-center/testimonials/ [R=301,L]
RewriteRule ^about\.html$ https://www.schooloffreelancing.com/about-us/ [R=301,L]
RewriteRule ^faq\.html$ https://www.schooloffreelancing.com/resource-center/faqs/ [R=301,L]
RewriteRule ^privacy-policy\.html$ https://www.schooloffreelancing.com/legal/privacy-policy/ [R=301,L]
RewriteRule ^terms\.html$ https://www.schooloffreelancing.com/legal/terms-and-conditions/ [R=301,L]
RewriteRule ^contact\.html$ https://www.schooloffreelancing.com/contact-us/ [R=301,L]

##################################################
# Redirect deleted section folders to their new
# equivalents from the 2026-07 site restructure
##################################################
RewriteRule ^training/enroll(/.*)?$ https://www.schooloffreelancing.com/contact-us/ [R=301,L]
RewriteRule ^training/oldenroll(/.*)?$ https://www.schooloffreelancing.com/contact-us/ [R=301,L]
RewriteRule ^training/enroll1(/.*)?$ https://www.schooloffreelancing.com/contact-us/ [R=301,L]
RewriteRule ^training/files(/.*)?$ https://www.schooloffreelancing.com/contact-us/ [R=301,L]
RewriteRule ^training/?$ https://www.schooloffreelancing.com/freelancing-training/ [R=301,L]
RewriteRule ^tech-support/get-support/?$ https://www.schooloffreelancing.com/linux-ai-services/ [R=301,L]
RewriteRule ^tech-support/?$ https://www.schooloffreelancing.com/linux-ai-services/ [R=301,L]
RewriteRule ^linux-it-services/?$ https://www.schooloffreelancing.com/linux-ai-services/ [R=301,L]
RewriteRule ^linux-it-services/(.+)$ https://www.schooloffreelancing.com/linux-ai-services/$1 [R=301,L]
RewriteRule ^get-started/?$ https://www.schooloffreelancing.com/contact-us/ [R=301,L]
RewriteRule ^about/?$ https://www.schooloffreelancing.com/about-us/ [R=301,L]
RewriteRule ^contact/?$ https://www.schooloffreelancing.com/contact-us/ [R=301,L]
RewriteRule ^testimonials/?$ https://www.schooloffreelancing.com/resource-center/testimonials/ [R=301,L]
RewriteRule ^faq/?$ https://www.schooloffreelancing.com/resource-center/faqs/ [R=301,L]
RewriteRule ^terms/?$ https://www.schooloffreelancing.com/legal/terms-and-conditions/ [R=301,L]
RewriteRule ^privacy/?$ https://www.schooloffreelancing.com/legal/privacy-policy/ [R=301,L]
RewriteRule ^refund/?$ https://www.schooloffreelancing.com/legal/refund-policy/ [R=301,L]
RewriteRule ^training-rules/?$ https://www.schooloffreelancing.com/legal/training-rules/ [R=301,L]
RewriteRule ^verify/?$ https://www.schooloffreelancing.com/legal/credential-verification/ [R=301,L]
RewriteRule ^location/?$ https://www.schooloffreelancing.com/locations/ [R=301,L]
RewriteRule ^location/(.+)$ https://www.schooloffreelancing.com/locations/$1 [R=301,L]

##################################################
# Force HTTPS + www (canonical host: https://www.schooloffreelancing.com)
# Placed after the legacy-path rules above so an old
# URL requested over http/non-www resolves in a single
# 301 hop straight to its new canonical path, instead of
# first bouncing to the old path on https+www and only
# then hitting the legacy-path rule on a second request.
##################################################
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.schooloffreelancing.com%{REQUEST_URI} [L,R=301]

##################################################
# Internally load index.html for clean folder URLs
##################################################
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L]

##################################################
# Browser Cache
##################################################
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType text/javascript "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/manifest+json "access plus 1 week"
    ExpiresByType application/xml "access plus 1 day"
    ExpiresByType text/plain "access plus 1 day"
</IfModule>

##################################################
# GZIP Compression
##################################################
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/manifest+json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

##################################################
# Security Headers
##################################################
<IfModule mod_headers.c>
    Header always set X-Frame-Options SAMEORIGIN
    Header always set X-Content-Type-Options nosniff
    Header always set Referrer-Policy strict-origin-when-cross-origin
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
